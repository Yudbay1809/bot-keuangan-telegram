# Bot Token dari @BotFather
BOT_TOKEN=your_bot_token_here

# Path untuk database SQLite
# Lokal: ./data/keuangan.db
# Railway (dengan Volume mount ke /data): /data/keuangan.db
DB_PATH=./data/keuangan.db

# Opsional mode journal SQLite:
# - Railway disarankan DELETE untuk volume network storage
# - Lokal disarankan WAL
# SQLITE_JOURNAL_MODE=DELETE
